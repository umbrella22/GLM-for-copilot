# Normalize line endings to LF for all text files.
# This prevents the recurring CRLF/LF churn on Windows where git's
# core.autocrlf=true conflicts with prettier's LF output, causing
# spurious "modified" status and format-check failures.

* text=auto eol=lf

# Explicit LF for source and config files (belt-and-suspenders).
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.mts text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific scripts keep CRLF (PowerShell / batch are CRLF-native).
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.vsix binary
