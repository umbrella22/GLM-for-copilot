{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Current VS Code)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "pnpm: watch"
    },
    {
      "name": "Run Extension (Insiders via CLI)",
      "type": "node",
      "request": "attach",
      "port": 9333,
      "timeout": 30000,
      "continueOnAttach": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "Launch Extension Host (Insiders CLI)"
    },
    {
      "name": "Run Extension (Stable via CLI)",
      "type": "node",
      "request": "attach",
      "port": 9334,
      "timeout": 30000,
      "continueOnAttach": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "Launch Extension Host (Stable CLI)"
    }
  ]
}
