{
  "name": "glm-for-vscode-copilot",
  "displayName": "GLM for VsCode Copilot",
  "description": "Pick GLM-5.2, GLM-4.6V-Flash, GLM-5V-Turbo, and GLM-5-Turbo from the Copilot Chat model picker. Vision, thinking mode, agent tools — BYOK.",
  "icon": "resources/icon.png",
  "version": "0.5.1",
  "packageManager": "pnpm@11.7.0",
  "publisher": "ikaros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/umbrella22/glm-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24.11.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "z.ai",
    "bigmodel",
    "glm",
    "glm 5",
    "glm-5",
    "glm coding plan",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "glm",
        "displayName": "GLM"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "glm-copilot.mcp-servers",
        "label": "GLM Copilot MCP Servers"
      }
    ],
    "commands": [
      {
        "command": "glm-copilot.setApiKey",
        "title": "%glm-copilot.command.setApiKey%"
      },
      {
        "command": "glm-copilot.getApiKey",
        "title": "%glm-copilot.command.getApiKey%"
      },
      {
        "command": "glm-copilot.queryUsage",
        "title": "%glm-copilot.command.queryUsage%"
      },
      {
        "command": "glm-copilot.clearApiKey",
        "title": "%glm-copilot.command.clearApiKey%"
      },
      {
        "command": "glm-copilot.manageModels",
        "title": "%glm-copilot.command.manageModels%"
      },
      {
        "command": "glm-copilot.setVisionModel",
        "title": "%glm-copilot.command.setVisionModel%"
      },
      {
        "command": "glm-copilot.openSettings",
        "title": "%glm-copilot.command.openSettings%"
      },
      {
        "command": "glm-copilot.showLogs",
        "title": "%glm-copilot.command.showLogs%"
      },
      {
        "command": "glm-copilot.openRequestDumpsFolder",
        "title": "%glm-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "glmGettingStarted",
        "title": "%glm-copilot.walkthrough.title%",
        "description": "%glm-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%glm-copilot.walkthrough.setApiKey.title%",
            "description": "%glm-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:glm-copilot.manageModels",
              "onCommand:glm-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%glm-copilot.walkthrough.showModels.title%",
            "description": "%glm-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%glm-copilot.walkthrough.advancedSettings.title%",
            "description": "%glm-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%glm-copilot.config.title%",
      "properties": {
        "glm-copilot.modelManagement": {
          "type": "object",
          "default": {
            "version": 1
          },
          "scope": "resource",
          "tags": [
            "advanced"
          ],
          "required": [
            "version"
          ],
          "additionalProperties": false,
          "markdownDescription": "%glm-copilot.config.modelManagement.description%",
          "properties": {
            "version": {
              "type": "number",
              "enum": [
                1
              ],
              "description": "%glm-copilot.config.modelManagement.version.description%"
            },
            "defaultConnection": {
              "type": "object",
              "additionalProperties": false,
              "description": "%glm-copilot.config.modelManagement.defaultConnection.description%",
              "properties": {
                "endpoint": {
                  "type": "string",
                  "enum": [
                    "china-coding",
                    "china-standard",
                    "china-anthropic",
                    "international-coding",
                    "international-standard",
                    "international-anthropic"
                  ],
                  "enumItemLabels": [
                    "%glm-copilot.config.endpoint.chinaCoding.label%",
                    "%glm-copilot.config.endpoint.chinaStandard.label%",
                    "%glm-copilot.config.endpoint.chinaAnthropic.label%",
                    "%glm-copilot.config.endpoint.internationalCoding.label%",
                    "%glm-copilot.config.endpoint.internationalStandard.label%",
                    "%glm-copilot.config.endpoint.internationalAnthropic.label%"
                  ],
                  "description": "%glm-copilot.config.modelManagement.endpoint.description%"
                },
                "baseUrl": {
                  "type": "string",
                  "description": "%glm-copilot.config.modelManagement.baseUrl.description%"
                }
              }
            },
            "models": {
              "type": "object",
              "description": "%glm-copilot.config.modelManagement.models.description%",
              "propertyNames": {
                "minLength": 1,
                "pattern": "^\\S(?:.*\\S)?$"
              },
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "apiModelId": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^\\S(?:.*\\S)?$",
                    "description": "%glm-copilot.config.modelManagement.apiModelId.description%"
                  },
                  "endpointRoute": {
                    "type": "string",
                    "enum": [
                      "default",
                      "same-region-standard",
                      "china-coding",
                      "china-standard",
                      "china-anthropic",
                      "international-coding",
                      "international-standard",
                      "international-anthropic"
                    ],
                    "enumItemLabels": [
                      "%glm-copilot.config.modelEndpointOverrides.default.label%",
                      "%glm-copilot.config.modelEndpointOverrides.sameRegionStandard.label%",
                      "%glm-copilot.config.endpoint.chinaCoding.label%",
                      "%glm-copilot.config.endpoint.chinaStandard.label%",
                      "%glm-copilot.config.endpoint.chinaAnthropic.label%",
                      "%glm-copilot.config.endpoint.internationalCoding.label%",
                      "%glm-copilot.config.endpoint.internationalStandard.label%",
                      "%glm-copilot.config.endpoint.internationalAnthropic.label%"
                    ],
                    "description": "%glm-copilot.config.modelManagement.endpointRoute.description%"
                  },
                  "visionMode": {
                    "type": "string",
                    "enum": [
                      "proxy",
                      "native"
                    ],
                    "description": "%glm-copilot.config.modelManagement.visionMode.description%"
                  }
                }
              }
            },
            "customModels": {
              "type": "object",
              "description": "%glm-copilot.config.modelManagement.customModels.description%",
              "propertyNames": {
                "minLength": 1,
                "pattern": "^\\S(?:.*\\S)?$"
              },
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "null",
                    "description": "%glm-copilot.config.modelManagement.customModels.tombstone.description%"
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "%glm-copilot.config.modelManagement.customModels.id.description%"
                      },
                      "name": {
                        "type": "string",
                        "description": "%glm-copilot.config.customModels.name.description%"
                      },
                      "contextWindowTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.contextWindowTokens.description%"
                      },
                      "maxInputTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.maxInputTokens.description%"
                      },
                      "maxOutputTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.maxOutputTokens.description%"
                      },
                      "toolCalling": {
                        "type": "boolean",
                        "description": "%glm-copilot.config.customModels.toolCalling.description%"
                      },
                      "thinking": {
                        "type": "boolean",
                        "description": "%glm-copilot.config.customModels.thinking.description%"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "glm-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%glm-copilot.config.maxTokens.description%"
        },
        "glm-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%glm-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "glm-copilot.visionModel": {
          "type": "string",
          "default": "",
          "tags": [
            "advanced"
          ],
          "markdownDescription": "%glm-copilot.config.visionModel.description%"
        },
        "glm-copilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe all image attachments in this message.\n\nIf there is one image, describe it directly.\nIf there are multiple images:\n1. Describe each image separately, preserving their order.\n2. Then provide a combined description explaining the overall context and relationships across the images.\n\nReturn one concise factual description suitable for inserting into a text-only chat prompt. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
          "markdownDescription": "%glm-copilot.config.visionPrompt.description%"
        },
        "glm-copilot.mcp.zai-mcp-server.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%glm-copilot.config.mcp.zai-mcp-server.enabled.description%"
        },
        "glm-copilot.mcp.web-search-prime.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%glm-copilot.config.mcp.web-search-prime.enabled.description%"
        },
        "glm-copilot.mcp.web-reader.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%glm-copilot.config.mcp.web-reader.enabled.description%"
        },
        "glm-copilot.mcp.zread.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%glm-copilot.config.mcp.zread.enabled.description%"
        },
        "glm-copilot.imageHandlingPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "[Image Handling]\nAttached images are stored as local files; their paths appear in the conversation as \"[Image attached at local file: <path>]\". You cannot see images inline — they must be read through an image-capable MCP tool. The file name is a content hash, so the same path always refers to the same image.\n\nBefore reading an image, check whether this conversation already contains an analysis of it (a prior image-tool result, or the one-line digest you emit after analyzing). Reuse that analysis whenever it already answers the user's current question — do not re-read out of habit. Read the image again only when:\n(a) it has not been analyzed yet in this conversation;\n(b) the current question needs detail the prior analysis did not cover; or\n(c) the image may have changed since (for example, the user edited the UI and re-captured it).\n\nAfter you read an image, end with a one-line digest so later turns can reuse it without re-reading:\n[Image digest | <label/path> | <type: ui-mockup | error-screenshot | diagram | …> | <key facts: layout, colors, text, sizes, errors> | <open questions>]\nKeep it to one line — it is an index, not a full description; update it if you re-read and learn more.\n\nNever invent the contents of an image you have not actually read — if analysis is needed and none exists yet, call the tool. If a read fails, returns nothing useless, or leaves you uncertain, say so explicitly rather than guessing; the user must be able to tell when your understanding of an image may be wrong.\n\nWhen the images at hand are stale, missing, or do not show the current state of the problem — for example the user has changed the code and is now reporting a visual bug, or a screenshot is too low-resolution to read an error — ask the user for a fresh, specific screenshot to ground your diagnosis. Ask only when a new capture would actually change your next step; otherwise proceed from what you have and state your assumptions. Request something concrete (the current top nav, the full error dialog with its stack trace), not a vague \"send a screenshot\".\n\nChoose the most appropriate image tool for the image type and the user's intent, and call it directly — do not mention tool names in your reply unless you are invoking that tool.\n",
          "markdownDescription": "%glm-copilot.config.imageHandlingPrompt.description%"
        },
        "glm-copilot.imageStoredPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "[{0} attached at local file: {1}]\nThis image cannot be displayed inline; read it with an image-capable MCP tool. The file name is a content hash — if you have already analyzed this path in this conversation, reuse that analysis unless you need new detail or the image has changed.",
          "markdownDescription": "%glm-copilot.config.imageStoredPrompt.description%"
        },
        "glm-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%glm-copilot.config.debugMode.minimal.label%",
            "%glm-copilot.config.debugMode.metadata.label%",
            "%glm-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%glm-copilot.config.debugMode.minimal.description%",
            "%glm-copilot.config.debugMode.metadata.description%",
            "%glm-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%glm-copilot.config.debugMode.description%"
        },
        "glm-copilot.mcp.servers": {
          "type": "object",
          "default": {
            "zai-mcp-server": {
              "type": "stdio",
              "label": "ZAI MCP Server",
              "detail": "GLM 官方聚合 MCP，含视觉识别等能力",
              "enabled": true,
              "command": "npx",
              "args": ["-y", "@z_ai/mcp-server"]
            },
            "web-search-prime": {
              "type": "http",
              "label": "Web Search Prime",
              "detail": "GLM 官方网页搜索",
              "enabled": true,
              "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
            },
            "web-reader": {
              "type": "http",
              "label": "Web Reader",
              "detail": "GLM 官方网页内容抓取",
              "enabled": true,
              "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
            },
            "zread": {
              "type": "http",
              "label": "Zread",
              "detail": "GLM 官方深度阅读",
              "enabled": true,
              "url": "https://open.bigmodel.cn/api/mcp/zread/mcp"
            }
          },
          "scope": "application",
          "markdownDescription": "%glm-copilot.config.mcp.servers.description%",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "object",
                "required": [
                  "type",
                  "label",
                  "command"
                ],
                "properties": {
                  "type": { "type": "string", "enum": ["stdio"] },
                  "label": { "type": "string" },
                  "detail": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "command": { "type": "string" },
                  "args": { "type": "array", "items": { "type": "string" } },
                  "authEnvKey": { "type": "string" }
                }
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "label",
                  "url"
                ],
                "properties": {
                  "type": { "type": "string", "enum": ["http"] },
                  "label": { "type": "string" },
                  "detail": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "url": { "type": "string" },
                  "authScheme": { "type": "string", "enum": ["bearer", "none"] }
                }
              }
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "vp pack",
    "watch": "vp pack --watch",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "format": "vp fmt --write src/ test/ vite.config.mts",
    "format:check": "vp fmt --check src/ test/ vite.config.mts",
    "package": "vp run vsix"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "1.0.2",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "vitest": "4.1.9"
  }
}
