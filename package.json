{
  "name": "glm-for-vscode-copilot",
  "displayName": "GLM for VsCode Copilot",
  "description": "Pick GLM-5.2, GLM-4.6V-Flash, GLM-5V-Turbo, and GLM-5-Turbo from the Copilot Chat model picker. Vision, thinking mode, agent tools — BYOK.",
  "icon": "resources/icon.png",
  "version": "0.6.0",
  "packageManager": "pnpm@11.7.0",
  "publisher": "ikaros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/umbrella22/glm-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24.11.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "z.ai",
    "bigmodel",
    "glm",
    "glm 5",
    "glm-5",
    "glm coding plan",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "glm",
        "displayName": "GLM"
      }
    ],
    "commands": [
      {
        "command": "glm-copilot.setApiKey",
        "title": "%glm-copilot.command.setApiKey%"
      },
      {
        "command": "glm-copilot.getApiKey",
        "title": "%glm-copilot.command.getApiKey%"
      },
      {
        "command": "glm-copilot.queryUsage",
        "title": "%glm-copilot.command.queryUsage%"
      },
      {
        "command": "glm-copilot.clearApiKey",
        "title": "%glm-copilot.command.clearApiKey%"
      },
      {
        "command": "glm-copilot.manageModels",
        "title": "%glm-copilot.command.manageModels%"
      },
      {
        "command": "glm-copilot.setVisionModel",
        "title": "%glm-copilot.command.setVisionModel%"
      },
      {
        "command": "glm-copilot.openSettings",
        "title": "%glm-copilot.command.openSettings%"
      },
      {
        "command": "glm-copilot.showLogs",
        "title": "%glm-copilot.command.showLogs%"
      },
      {
        "command": "glm-copilot.openRequestDumpsFolder",
        "title": "%glm-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "glmGettingStarted",
        "title": "%glm-copilot.walkthrough.title%",
        "description": "%glm-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%glm-copilot.walkthrough.setApiKey.title%",
            "description": "%glm-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:glm-copilot.manageModels",
              "onCommand:glm-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%glm-copilot.walkthrough.showModels.title%",
            "description": "%glm-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%glm-copilot.walkthrough.advancedSettings.title%",
            "description": "%glm-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%glm-copilot.config.title%",
      "properties": {
        "glm-copilot.modelManagement": {
          "type": "object",
          "default": {
            "version": 1
          },
          "scope": "resource",
          "tags": [
            "advanced"
          ],
          "required": [
            "version"
          ],
          "additionalProperties": false,
          "markdownDescription": "%glm-copilot.config.modelManagement.description%",
          "properties": {
            "version": {
              "type": "number",
              "enum": [
                1
              ],
              "description": "%glm-copilot.config.modelManagement.version.description%"
            },
            "defaultConnection": {
              "type": "object",
              "additionalProperties": false,
              "description": "%glm-copilot.config.modelManagement.defaultConnection.description%",
              "properties": {
                "endpoint": {
                  "type": "string",
                  "enum": [
                    "china-coding",
                    "china-standard",
                    "china-anthropic",
                    "international-coding",
                    "international-standard",
                    "international-anthropic"
                  ],
                  "enumItemLabels": [
                    "%glm-copilot.config.endpoint.chinaCoding.label%",
                    "%glm-copilot.config.endpoint.chinaStandard.label%",
                    "%glm-copilot.config.endpoint.chinaAnthropic.label%",
                    "%glm-copilot.config.endpoint.internationalCoding.label%",
                    "%glm-copilot.config.endpoint.internationalStandard.label%",
                    "%glm-copilot.config.endpoint.internationalAnthropic.label%"
                  ],
                  "description": "%glm-copilot.config.modelManagement.endpoint.description%"
                },
                "baseUrl": {
                  "type": "string",
                  "description": "%glm-copilot.config.modelManagement.baseUrl.description%"
                }
              }
            },
            "models": {
              "type": "object",
              "description": "%glm-copilot.config.modelManagement.models.description%",
              "propertyNames": {
                "minLength": 1,
                "pattern": "^\\S(?:.*\\S)?$"
              },
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "apiModelId": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^\\S(?:.*\\S)?$",
                    "description": "%glm-copilot.config.modelManagement.apiModelId.description%"
                  },
                  "endpointRoute": {
                    "type": "string",
                    "enum": [
                      "default",
                      "same-region-standard",
                      "china-coding",
                      "china-standard",
                      "china-anthropic",
                      "international-coding",
                      "international-standard",
                      "international-anthropic"
                    ],
                    "enumItemLabels": [
                      "%glm-copilot.config.modelEndpointOverrides.default.label%",
                      "%glm-copilot.config.modelEndpointOverrides.sameRegionStandard.label%",
                      "%glm-copilot.config.endpoint.chinaCoding.label%",
                      "%glm-copilot.config.endpoint.chinaStandard.label%",
                      "%glm-copilot.config.endpoint.chinaAnthropic.label%",
                      "%glm-copilot.config.endpoint.internationalCoding.label%",
                      "%glm-copilot.config.endpoint.internationalStandard.label%",
                      "%glm-copilot.config.endpoint.internationalAnthropic.label%"
                    ],
                    "description": "%glm-copilot.config.modelManagement.endpointRoute.description%"
                  },
                  "visionMode": {
                    "type": "string",
                    "enum": [
                      "proxy",
                      "native"
                    ],
                    "description": "%glm-copilot.config.modelManagement.visionMode.description%"
                  }
                }
              }
            },
            "customModels": {
              "type": "object",
              "description": "%glm-copilot.config.modelManagement.customModels.description%",
              "propertyNames": {
                "minLength": 1,
                "pattern": "^\\S(?:.*\\S)?$"
              },
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "null",
                    "description": "%glm-copilot.config.modelManagement.customModels.tombstone.description%"
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "%glm-copilot.config.modelManagement.customModels.id.description%"
                      },
                      "name": {
                        "type": "string",
                        "description": "%glm-copilot.config.customModels.name.description%"
                      },
                      "contextWindowTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.contextWindowTokens.description%"
                      },
                      "maxInputTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.maxInputTokens.description%"
                      },
                      "maxOutputTokens": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991,
                        "description": "%glm-copilot.config.customModels.maxOutputTokens.description%"
                      },
                      "toolCalling": {
                        "type": "boolean",
                        "description": "%glm-copilot.config.customModels.toolCalling.description%"
                      },
                      "thinking": {
                        "type": "boolean",
                        "description": "%glm-copilot.config.customModels.thinking.description%"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "glm-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%glm-copilot.config.maxTokens.description%"
        },
        "glm-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%glm-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "glm-copilot.visionModel": {
          "type": "string",
          "default": "",
          "tags": [
            "advanced"
          ],
          "markdownDescription": "%glm-copilot.config.visionModel.description%"
        },
        "glm-copilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe all image attachments in this message.\n\nIf there is one image, describe it directly.\nIf there are multiple images:\n1. Describe each image separately, preserving their order.\n2. Then provide a combined description explaining the overall context and relationships across the images.\n\nReturn one concise factual description suitable for inserting into a text-only chat prompt. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
          "markdownDescription": "%glm-copilot.config.visionPrompt.description%"
        },
        "glm-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%glm-copilot.config.debugMode.minimal.label%",
            "%glm-copilot.config.debugMode.metadata.label%",
            "%glm-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%glm-copilot.config.debugMode.minimal.description%",
            "%glm-copilot.config.debugMode.metadata.description%",
            "%glm-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%glm-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "vp pack",
    "watch": "vp pack --watch",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "format": "vp fmt --write src/ test/ vite.config.mts",
    "format:check": "vp fmt --check src/ test/ vite.config.mts",
    "package": "vp run vsix"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "1.0.2",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "vitest": "4.1.9"
  }
}
